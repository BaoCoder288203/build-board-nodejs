# Copy to .env and fill secrets. Never commit real secrets.

NODE_ENV=development
PORT=4000
APP_NAME=BuildBoard
APP_URL=http://localhost:4000
API_PREFIX=/api/v1

DATABASE_URL=postgresql://buildboard:buildboard@localhost:5433/buildboard
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-to-a-long-random-string-at-least-32
JWT_EXPIRES=15m
REFRESH_SECRET=change-me-to-another-long-random-string-32
REFRESH_EXPIRES=30d

CORS_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

STORAGE_DRIVER=local
UPLOAD_DIR=uploads

# Optional Cloudinary (when STORAGE_DRIVER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=buildboard

# Local mail (Mailpit) or Resend
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=BuildBoard <noreply@buildboard.local>
EMAIL_FROM=BuildBoard <noreply@buildboard.local>
RESEND_API_KEY=

ENABLE_AI=false
ENABLE_SOCKET=true
ENABLE_SIGNUP=true
LOG_LEVEL=debug
